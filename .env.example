# Copy this file to `.env` and fill in the values. `.env` is gitignored; this example is committed.

# --- Model (OpenRouter, "Path 1" direct env) ---
ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_AUTH_TOKEN=            # OpenRouter API key (sk-or-...); requires ~$5 one-time credit to activate
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek/deepseek-v4-flash
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek/deepseek-v4-flash:free

# --- Job sources ---
ADZUNA_APP_ID=                   # developer.adzuna.com
ADZUNA_APP_KEY=
SERPER_API_KEY=                  # serper.dev (dorks + contact search)

# --- Contact / email finder ---
HUNTER_API_KEY=                  # hunter.io (LAST resort only)
HUNTER_ENABLED=false             # keep false for first smoke test
HUNTER_MONTHLY_CAP=50            # hard cap on Hunter credits/month

# --- Email (Gmail via GongRzhe OAuth MCP) ---
# Put your Google OAuth client JSON at ./secrets/gcp-oauth.keys.json (gitignored).
# Token is written to ./secrets/gmail-credentials.json after running:
#   set -a; source .env; set +a; npx -y @gongrzhe/server-gmail-autoauth-mcp auth
GMAIL_OAUTH_PATH=./secrets/gcp-oauth.keys.json
GMAIL_CREDENTIALS_PATH=./secrets/gmail-credentials.json
# (legacy SMTP fallback — unused with GongRzhe)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Telegram channel ---
TELEGRAM_BOT_TOKEN=              # from @BotFather

# --- Agent tuning ---
MATCH_THRESHOLD=60               # only pursue jobs scored >= this
SEND_LIMIT_PER_RUN=1             # cap real sends per run (raise once trusted)
MAX_APPLIES_PER_DAY=5            # cap real LinkedIn Easy Apply submissions per day (burner account)
MAX_CONNECTS_PER_DAY=10          # cap real LinkedIn connection requests sent per day (main account)
MAX_LINKEDIN_SEARCHES_PER_DAY=20 # cap LinkedIn people-search lookups per day (main account)
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek/deepseek-v4-pro
